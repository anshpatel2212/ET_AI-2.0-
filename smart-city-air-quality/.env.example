# ============================================================
# 🌃 Smart City Air Quality Intelligence Platform
# Environment Configuration
# Copy to .env and fill all values before running
# ============================================================

# ── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# ── Backend — Node Express ────────────────────────────────
NODE_ENV=development
PORT=4000
JWT_SECRET=<openssl rand -hex 64>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=<openssl rand -hex 64>
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/smart_city_aqi
REDIS_URL=redis://default:pass@host:6379
ML_SERVICE_URL=http://localhost:8000

# ── Air Quality APIs ──────────────────────────────────────
# Get from: https://aqicn.org/data-platform/token/
WAQI_TOKEN=
# Free at: https://openaq.org/
OPENAQ_API_KEY=
# Free at: https://openweathermap.org/api
OWM_API_KEY=
# Free at: https://account.mapbox.com/
MAPBOX_TOKEN=
# Free at: https://developer.tomtom.com/
TOMTOM_API_KEY=
# Free at: https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_KEY=
# SciHub Copernicus account: https://scihub.copernicus.eu/
COPERNICUS_USER=
COPERNICUS_PASS=

# ── AI / ML APIs ──────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Notifications ─────────────────────────────────────────
TWILIO_SID=ACxxxx
TWILIO_TOKEN=xxxxx
TWILIO_FROM=+1xxxxxxxx
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM=alerts@yourcity.gov.in
FCM_PROJECT_ID=xxx
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
FCM_CLIENT_EMAIL=firebase-adminsdk@...

# ── AWS S3 ────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=smart-city-aqi
S3_PHOTOS_FOLDER=citizen-reports/
S3_SATELLITE_FOLDER=satellite-imagery/

# ── ML Service (Python) ──────────────────────────────────
PYTHON_PORT=8000
MLFLOW_TRACKING_URI=http://localhost:5000
